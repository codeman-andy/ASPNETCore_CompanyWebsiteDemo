@model IEnumerable<EmployeeManagement.Models.ApplicationUser>

@{
	ViewBag.Title = "All Users";
}

<h1>All Users</h1>

@if (Model.Any())
{
	<a asp-controller="Account" asp-action="Register" class="btn btn-primary mb-3" style="width:auto">
		Add new user
	</a>

	foreach (var user in Model)
	{
		<div class="card mb-3">
			<div class="card-header">
				User ID: @user.Id
			</div>

			<div class="card-body">
				<h5 class="card-title">
					@user.UserName
				</h5>
				@if (!string.IsNullOrEmpty(user.City))
				{
					<h5 class="card-title">
						@user.City
					</h5>
				}
			</div>

			<div class="card-footer">
				<form method="post" asp-controller="Administration" asp-action="DeleteUser" asp-route-id="@user.Id">
					<a asp-controller="Administration" asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-primary">Edit</a>

					<!-- 'id' attribute must be unique (using the Id-property of the 'user' variable) because otherwise we would be -->
					<!-- pressing every single 'Yes' button of every 'Delete' span in the whole page source code.                   -->
					<span id="deleteSpan_@user.Id">
						<!-- Here, 'return false' prevents the page to go back to the top after the on-click event -->
						<a href="#" class="btn btn-danger" onclick="confirmDelete('@user.Id', true); return false">
							Delete
						</a>
					</span>

					<span id="confirmDeleteSpan_@user.Id" style="display:none">
						<span>Are you sure?</span>
						<button type="submit" class="btn btn-danger">Yes</button>
						<!-- Here, 'return false' prevents the page to go back to the top after the on-click event -->
						<a href="#" class="btn btn-primary" onclick="confirmDelete('@user.Id', false); return false">No</a>
					</span>
				</form>
			</div>
		</div>
	}
}
else
{
	<div class="card">
		<div class="card-header">
			No users created yet
		</div>

		<div class="card-body">
			<h5 class="card-title">
				Use the button below to Create a User
			</h5>

			<a asp-controller="Account" asp-action="Register" class="btn btn-primary" style="width:auto">
				Add New User
			</a>
		</div>
	</div>
}

@section Scripts {
	<script src="~/js/customscript.js"></script>
}