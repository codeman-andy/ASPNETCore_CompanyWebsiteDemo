@if (ViewBag.ErrorTitle == null)
{
	<h3>
		An error has occured while processing your request.
		The support team has been notified and are working on a fix.
	</h3>

	<h5>
		Please, contact us on some@email.com if you need further support.
	</h5>
}
else
{
	<h1 class="text-danger">@ViewBag.ErrorTitle</h1>
	<h6 class="text-danger">@ViewBag.ErrorMessage</h6>
}


















